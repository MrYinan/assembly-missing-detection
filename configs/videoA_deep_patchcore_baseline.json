{
  "arch": "resnet18",
  "pretrained": true,
  "input_size": 224,
  "layers": [
    "layer2",
    "layer3"
  ],
  "device": "auto",
  "batch_size": 16,
  "allow_untrained_fallback": false,
  "patch_neighborhood_size": 1,
  "memory_sampling_method": "random",
  "export_heatmaps": false,
  "max_memory_patches": 30000,
  "threshold_quantile": 0.99,
  "threshold_margin": 1.05,
  "top_percent": 0.01,
  "product_alert_norm_threshold": 0.94,
  "videoA_use_yellow_gate": true,
  "videoA_yellow_gate_quantile": 0.01,
  "videoA_yellow_gate_margin": 0.75,
  "videoA_min_yellow_floor": 0.26,
  "seed": 42,
  "x_min": 410,
  "x_max": 1275,
  "y_min": 230,
  "y_max": 455,
  "min_radius": 45,
  "max_radius": 60,
  "max_faces": 1,
  "inspection_center_x": 600,
  "inspection_selection": "nearest",
  "yellow_h_min": 14,
  "yellow_h_max": 45,
  "min_inner_saturation": 45.0,
  "min_face_yellow_ratio": 0.1,
  "nms_radius_factor": 1.35,
  "base_width": 1280,
  "base_height": 720,
  "videoA_fuse_yellow_score": true,
  "temporal_smoothing": true,
  "hysteresis_high": 0.95,
  "hysteresis_low": 0.85,
  "keep_ng_frames": 3
}
